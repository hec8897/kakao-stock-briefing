# Anthropic API 키 (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# AI 모델 (기본값: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# AI 뉴스 요약·시황 코멘트 사용 여부 (false면 가격 정보만 전송)
ENABLE_AI=true

# 카카오 REST API 키 (카카오 개발자 콘솔 > 내 애플리케이션 > 앱 키)
KAKAO_REST_API_KEY=...

# 카카오 리프레시 토큰 (npm run auth 로 1회 발급)
KAKAO_REFRESH_TOKEN=...
